# --- AI ---
ANTHROPIC_API_KEY=            # server-only; never exposed to browser

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=    # server-only; all data access (RLS is deny-all)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # present for client lib init only; grants no data access

# --- Admin ---
ADMIN_PASSWORD=               # single-admin login (constant-time compare)
ADMIN_SESSION_SECRET=         # signs the httpOnly admin cookie

# --- Site ---
NEXT_PUBLIC_SITE_URL=         # e.g. https://mri.ahamoment.example — drives sitemap/hreflang/OG
NEXT_PUBLIC_CALENDLY_URL=     # placeholder booking link
NEXT_PUBLIC_STRIPE_LINK_TEARDOWN=   # placeholder payment links (V1: may be empty)
NEXT_PUBLIC_STRIPE_LINK_SPRINT=
NEXT_PUBLIC_STRIPE_LINK_PACKAGE=
PRIVACY_CONTACT_EMAIL=        # shown on /privacy and report footer
NEXT_PUBLIC_PROMO_DEADLINE=   # honest promo deadline (YYYY-MM-DD); past/empty hides the banner & reverts to full price
MRI_DAILY_CAP=               # site-wide daily MRI cap (kill switch); default 50, set ≤0 to disable

# --- Email (optional; report is always shown on-screen regardless) ---
RESEND_API_KEY=              # from resend.com; unset = no emails sent
RESEND_FROM=                 # verified sender, e.g. "AhaMoment <noreply@yourdomain.com>"

# --- Blog (optional cross-promotion) ---
NEXT_PUBLIC_BLOG_URL=         # e.g. https://ahamoment.ghost.io ; set to show a "blog" link in the footer
